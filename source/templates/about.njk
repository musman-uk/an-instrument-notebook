<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <title>{{ title }}</title>
  <meta name="viewport" content="width=device-width, initial-scale=1">

  <!-- Handwritten font -->
  <link href="https://fonts.googleapis.com/css2?family=Caveat:wght@400;700&display=swap" rel="stylesheet">

  <style>
    body {
      margin: 0;
      padding: 2.5rem;
      font-family: ui-serif, Georgia, serif;
      background: #faf9f6;
      color: #333;
      line-height: 1.6;
    }

    header {
      margin-bottom: 3rem;
    }

    h1 {
      margin: 0;
      font-size: 2.4rem;
      letter-spacing: 0.5px;
    }

    .back-link {
      display: inline-block;
      margin-top: 1rem;
      font-size: 0.9rem;
      text-decoration: none;
      color: #666;
      border-left: 2px solid #ddd;
      padding-left: 0.4rem;
      opacity: 0.8;
    }

    .back-link:hover {
      opacity: 1;
      text-decoration: underline;
    }

    .season-card {
      padding: 1.2rem;
      background: #fffdf8;
      border-left: 4px solid #ccc;
      box-shadow: 0 2px 5px rgba(0,0,0,0.08);
      max-width: 520px;
    }
  </style>
</head>

<body>
  <header>
    <h1>{{ title }}</h1>
    <a href="/" class="back-link">Back to Seasonal Notes</a>
  </header>

  <main>
    {{ content | safe }}
  </main>
</body>
</html>
