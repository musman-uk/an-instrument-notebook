<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Seasonal Notes</title>

  <style>
    /* Page background */
    body {
      font-family: "Bradley Hand", cursive;
      background: #faf9f6;
      color: #222;
      margin: 0;
      padding: 1.2rem;
      line-height: 1.6;
      position: relative;
    }

    /* Sticky‑note style link */
    .about-link {
      position: fixed;
      top: 1rem;
      right: 1rem;
      background: #ffeeb0;
      border: 1px solid #d8cfa0;
      box-shadow: 3px 4px 7px rgba(0,0,0,0.2);
      padding: 0.6rem 1rem;
      transform: rotate(2deg);
      font-family: "Bradley Hand", cursive;
      text-decoration: none;
      color: #1a4b8c;
      z-index: 10;
    }

    /* Sticky‑note title */
    .title-card {
      background: #ffeeb0;
      border: 1px solid #d8cfa0;
      box-shadow: 3px 4px 7px rgba(0,0,0,0.2);
      color: #1a4b8c;
      padding: 1rem 2rem;
      font-size: 2rem;
      width: fit-content;
      margin: 0 auto 2.5rem auto;
      transform: rotate(-1deg);
      letter-spacing: 1px;
      position: relative;
      z-index: 2;
    }

    /* Grid layout */
    .seasons-grid {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 3rem;
      position: relative;
      z-index: 1;
    }

    /* Season block base */
    .season-block {
      padding: 2rem;
      border-radius: 6px;
      position: relative;
      overflow: hidden;
      isolation: isolate;
      color: #1a4b8c;
    }

    /* ---------------------------------------------------------
       UPDATED EXPRESSIVE WATERCOLOR PALETTES (OPTION B)
       --------------------------------------------------------- */

    /* SPRING */
    .spring {
      background: #e6f7e6;
      --tilt: -1deg;
    }
    .spring::before {
      content: "";
      position: absolute;
      inset: 0;
      background:
        radial-gradient(circle at 20% 30%, rgba(150,255,180,0.55), transparent 70%),
        radial-gradient(circle at 80% 70%, rgba(255,180,220,0.45), transparent 70%),
        radial-gradient(circle at 50% 50%, rgba(200,255,220,0.35), transparent 75%),
        radial-gradient(circle at 30% 80%, rgba(180,240,200,0.35), transparent 75%);
      z-index: 1;
    }
    .spring::after {
      content: "";
      position: absolute;
      inset: -40px;
      background:
        radial-gradient(circle at 10% 10%, rgba(255,200,230,0.30), transparent 70%),
        radial-gradient(circle at 90% 20%, rgba(180,255,210,0.30), transparent 70%),
        radial-gradient(circle at 20% 90%, rgba(220,255,230,0.30), transparent 70%);
      z-index: 0;
    }

    /* SUMMER */
    .summer {
      background: #ffe8b8;
      --tilt: 1deg;
    }
    .summer::before {
      content: "";
      position: absolute;
      inset: 0;
      background:
        radial-gradient(circle at 30% 20%, rgba(255,240,120,0.55), transparent 70%),
        radial-gradient(circle at 70% 80%, rgba(255,170,140,0.45), transparent 70%),
        radial-gradient(circle at 50% 50%, rgba(255,210,160,0.35), transparent 75%),
        radial-gradient(circle at 20% 60%, rgba(180,220,255,0.25), transparent 75%);
      z-index: 1;
    }
    .summer::after {
      content: "";
      position: absolute;
      inset: -40px;
      background:
        radial-gradient(circle at 15% 15%, rgba(255,235,150,0.30), transparent 70%),
        radial-gradient(circle at 85% 10%, rgba(255,180,140,0.30), transparent 70%),
        radial-gradient(circle at 10% 85%, rgba(255,200,160,0.30), transparent 70%);
      z-index: 0;
    }

    /* AUTUMN */
    .autumn {
      background: #f5d2b0;
      --tilt: -1deg;
    }
    .autumn::before {
      content: "";
      position: absolute;
      inset: 0;
      background:
        radial-gradient(circle at 20% 80%, rgba(200,110,50,0.55), transparent 70%),
        radial-gradient(circle at 80% 20%, rgba(230,140,70,0.45), transparent 70%),
        radial-gradient(circle at 50% 50%, rgba(180,90,40,0.35), transparent 75%),
        radial-gradient(circle at 60% 60%, rgba(120,70,30,0.25), transparent 75%);
      z-index: 1;
    }
    .autumn::after {
      content: "";
      position: absolute;
      inset: -40px;
      background:
        radial-gradient(circle at 12% 20%, rgba(210,130,70,0.30), transparent 70%),
        radial-gradient(circle at 88% 18%, rgba(180,90,50,0.30), transparent 70%),
        radial-gradient(circle at 18% 88%, rgba(230,150,90,0.30), transparent 70%);
      z-index: 0;
    }

    /* WINTER */
    .winter {
      background: #e2f0ff;
      --tilt: 1deg;
    }
    .winter::before {
      content: "";
      position: absolute;
      inset: 0;
      background:
        radial-gradient(circle at 50% 10%, rgba(180,220,255,0.55), transparent 70%),
        radial-gradient(circle at 30% 90%, rgba(200,240,255,0.45), transparent 70%),
        radial-gradient(circle at 50% 50%, rgba(210,235,255,0.35), transparent 75%),
        radial-gradient(circle at 70% 40%, rgba(200,190,255,0.25), transparent 75%);
      z-index: 1;
    }
    .winter::after {
      content: "";
      position: absolute;
      inset: -40px;
      background:
        radial-gradient(circle at 15% 15%, rgba(200,230,255,0.30), transparent 70%),
        radial-gradient(circle at 85% 12%, rgba(170,210,245,0.30), transparent 70%),
        radial-gradient(circle at 12% 88%, rgba(210,235,255,0.30), transparent 70%);
      z-index: 0;
    }

    /* Notes */
    .note {
      background: #ffeeb0;
      border: 1px solid #d8cfa0;
      box-shadow: 3px 4px 7px rgba(0,0,0,0.2);
      padding: 0.3rem;
      width: 100px;
      font-size: 0.65rem;
      transform: rotate(-3deg);
      margin: 0.25rem;
      opacity: 0;
      color: #1a4b8c;
      transition: opacity 0.6s ease, transform 0.6s ease;
      position: relative;
      z-index: 2;
    }

    .note.visible {
      opacity: 1;
      transform: rotate(var(--tilt-note, -1deg));
    }

    .notes-wrap {
      display: flex;
      flex-wrap: wrap;
      gap: 0.3rem;
      position: relative;
      z-index: 2;
    }

    @media (max-width: 700px) {
      .seasons-grid {
        grid-template-columns: 1fr;
      }
      .season-block {
        transform: rotate(0deg);
      }
    }
  </style>
</head>

<body>

  <a class="about-link" href="about/">About</a>

  <div class="title-card">Seasonal Notes</div>

  <div class="seasons-grid">

    {% for season in ["spring", "summer", "autumn", "winter"] %}
      <div class="season-block {{ season }}">
        <div class="season-title">{{ season | capitalize }}</div>

        <div class="notes-wrap">
          {% for note in collections.notes %}
            {% if note.data.season == season %}
              <div class="note">
                {{ note.templateContent | safe }}
              </div>
            {% endif %}
          {% endfor %}
        </div>
      </div>
    {% endfor %}

  </div>

  <script>
    document.addEventListener("DOMContentLoaded", () => {
      const notes = document.querySelectorAll(".note");
      notes.forEach((note, i) => {
        const delay = 200 + i * 120;
        setTimeout(() => {
          note.classList.add("visible");
        }, delay);
      });
    });
  </script>

</body>
</html>
