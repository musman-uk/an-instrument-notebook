<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <title>Seasonal Notes</title>

  <style>
    body {
      font-family: "Bradley Hand", cursive;
      background: #faf9f6;
      color: #222;
      margin: 0;
      padding: 2rem;
      line-height: 1.6;
    }

    /* Title card */
    .title-card {
      background: #fff8d6;
      color: #1a4b8c;
      padding: 1rem 2rem;
      border: 1px solid #e0dfd8;
      box-shadow: 2px 3px 6px rgba(0,0,0,0.1);
      font-size: 2rem;
      width: fit-content;
      margin: 0 auto 2rem auto;
      transform: rotate(-1deg);
      letter-spacing: 1px;
    }

    /* About link */
    .about-link {
      position: fixed;
      top: 1rem;
      right: 1rem;
      background: #fffef7;
      padding: 0.6rem 1rem;
      border: 1px solid #e0dfd8;
      box-shadow: 2px 3px 6px rgba(0,0,0,0.1);
      transform: rotate(2deg);
      font-family: "Bradley Hand", cursive;
      text-decoration: none;
      color: #222;
      z-index: 10;
    }

    /* Organic 2×2 seasonal layout */
    .seasons-grid {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 2rem;
    }

    .season-block {
      padding: 1.5rem;
      border-radius: 6px;
      box-shadow: 2px 3px 6px rgba(0,0,0,0.08);
      transform: rotate(var(--tilt));
    }

    /* Seasonal palettes */
    .spring { background: #e8fbe8; --tilt: -1deg; }
    .summer { background: #fff4c7; --tilt: 0.8deg; }
    .autumn { background: #ffe8d9; --tilt: -0.6deg; }
    .winter { background: #e7f1ff; --tilt: 1deg; }

    .season-title {
      font-size: 1.4rem;
      color: #1a4b8c;
      margin-bottom: 1rem;
      letter-spacing: 1px;
    }

    /* Notes */
    .note {
      background: #fffef7;
      padding: 0.7rem;
      width: 180px;
      border: 1px solid #e0dfd8;
      box-shadow: 2px 3px 6px rgba(0,0,0,0.1);
      transform: rotate(-1deg);
      font-size: 1rem;
      margin: 0.5rem;
      opacity: 0;
      transition: opacity 0.6s ease, transform 0.6s ease;
    }

    .note.visible {
      opacity: 1;
      transform: rotate(var(--tilt-note, -1deg));
    }

    .notes-wrap {
      display: flex;
      flex-wrap: wrap;
      gap: 0.5rem;
    }

    /* Mobile layout */
    @media (max-width: 700px) {
      .seasons-grid {
        grid-template-columns: 1fr;
      }
      .season-block {
        transform: rotate(0deg);
      }
    }
  </style>
</head>

<body>

  <a class="about-link" href="about/">About</a>

  <div class="title-card">Seasonal Notes</div>

  <div class="seasons-grid">

    {% for season in ["spring", "summer", "autumn", "winter"] %}
      <div class="season-block {{ season }}">
        <div class="season-title">{{ season | capitalize }}</div>

        <div class="notes-wrap">
          {% for note in collections.notes %}
            {% if note.data.season == season %}
              <div class="note">
                {{ note.templateContent | safe }}
              </div>
            {% endif %}
          {% endfor %}
        </div>
      </div>
    {% endfor %}

  </div>

  <script>
    document.addEventListener("DOMContentLoaded", () => {
      const notes = document.querySelectorAll(".note");

      notes.forEach((note, i) => {
        const delay = 200 + i * 120;
        setTimeout(() => {
          note.classList.add("visible");
        }, delay);
      });
    });
  </script>

</body>
</html>
