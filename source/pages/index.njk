<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">

  <title>Instrumental Notes</title>

  <style>
    :root {
      --coral: #FF6F61;
      --lavender: #B3AEDF;
    }

    /* Disable overscroll bounce on mobile */
    html, body {
      overscroll-behavior: none;
    }

    body {
      margin: 0;
      padding: 2rem 1.5rem;
      background:
        radial-gradient(circle at 20% 30%, rgba(255,111,97,0.25), transparent 65%),
        radial-gradient(circle at 80% 70%, rgba(122,95,255,0.25), transparent 65%),
        linear-gradient(160deg, #05070D, #0A0F1F, #1C2541);
      color: var(--lavender);
      font-family: "Cormorant Garamond", serif;
      min-height: 100vh;
      overflow-x: hidden;
      display: block;
    }

    /* PAGE WRAPPER — centers content without breaking layout */
    .page {
      max-width: 700px;
      margin: 0 auto;
    }

    /* Prelude link */
    .top-bar {
      width: 100%;
      display: flex;
      justify-content: flex-end;
      margin-bottom: 1.4rem;
      transform: translateY(-1.2rem);
    }

    .prelude-link {
      text-decoration: none;
      color: var(--coral);
      padding: 0.45rem 1rem;
      border-radius: 4px;
      background: rgba(255,111,97,0.12);
      border: 1px solid rgba(255,111,97,0.45);
      box-shadow: 0 0 10px rgba(255,111,97,0.55);
      font-size: 0.95rem;
      letter-spacing: 0.6px;
      backdrop-filter: blur(4px);
      transition: background 0.25s ease, box-shadow 0.25s ease, transform 0.2s ease;
    }

    .prelude-link:hover {
      background: rgba(255,111,97,0.25);
      box-shadow: 0 0 16px rgba(255,111,97,0.75);
      transform: translateY(-2px);
    }

    /* Musical notes */
    .note-cluster {
      display: flex;
      gap: 0.35rem;
      margin-bottom: 1rem;
      justify-content: center;
      width: 100%;
    }

    .note {
      font-size: 1.35rem;
      color: var(--lavender);
      text-shadow: 0 0 12px rgba(199,196,226,0.7);
      line-height: 1;
    }

    /* Title */
    .title {
      font-size: 2.8rem;
      letter-spacing: 1px;
      color: var(--coral);
      text-shadow: 0 0 18px rgba(255,111,97,0.85);
      margin-bottom: 2.5rem;
      text-align: center;
      width: 100%;
    }

    /* Instrument sections */
    .studio-sections {
      display: flex;
      flex-wrap: wrap;
      justify-content: center;
      gap: 1.4rem;
    }

    .studio-card {
      flex: 1 1 220px;
      max-width: 260px;
      box-sizing: border-box;

      padding: 1.4rem 1.2rem;
      background: rgba(10, 15, 30, 0.55);
      border: 1px solid rgba(255,111,97,0.25);
      border-radius: 6px;
      backdrop-filter: blur(4px);
      box-shadow: 0 0 18px rgba(255,111,97,0.18);

      text-decoration: none;
      color: var(--lavender);
      text-shadow: 0 0 6px rgba(199,196,226,0.25);
    }

    /* Image */
    .instrument-image {
      width: 100%;
      max-width: 200px;
      height: auto;
      object-fit: contain;
      display: block;
      margin: 0 auto 1rem auto;
      border-radius: 4px;
      opacity: 0.95;
    }

    .studio-title {
      font-size: 1.4rem;
      margin-bottom: 0.2rem;
      color: var(--coral);
      text-shadow: 0 0 12px rgba(255,111,97,0.55);
      text-align: center;
    }

    .studio-desc {
      font-size: 0.9rem;
      opacity: 0.9;
      color: var(--lavender);
      text-shadow: 0 0 6px rgba(199,196,226,0.25);
      text-align: center;
    }
  </style>
</head>

<body>

  <div class="page">

    <!-- Prelude link -->
    <div class="top-bar">
      <a class="prelude-link" href="./prelude/">Prelude</a>
    </div>

    <!-- Musical notes -->
    <div class="note-cluster">
      <div class="note">♫</div>
      <div class="note">♪</div>
      <div class="note">♫</div>
    </div>

    <!-- Title -->
    <div class="title">Instrumental Notes</div>

    <!-- Cards -->
    <div class="studio-sections">

      {% for note in collections.notes %}
        <div class="studio-card">

          <img 
            src="assets/images/{{ note.data.image }}" 
            alt="{{ note.data.title }}" 
            class="instrument-image"
            data-sound="assets/sounds/{{ note.data.sound }}"
          />

          <div class="studio-title">{{ note.data.title }}</div>
          <div class="studio-desc">{{ note.data.description }}</div>
        </div>
      {% endfor %}

    </div>

  </div>

  <!-- Sound playback script -->
  <script>
    document.addEventListener("DOMContentLoaded", () => {
      let currentlyPlaying = null;
      const images = document.querySelectorAll(".instrument-image");

      images.forEach(img => {
        let lastTap = 0;

        const audio = new Audio(img.dataset.sound);
        audio.addEventListener("error", () => {
          console.error(`Failed to load audio: ${img.dataset.sound}`);
        });

        // Desktop double-click
        img.addEventListener("dblclick", () => {
          if (currentlyPlaying && currentlyPlaying !== audio) {
            currentlyPlaying.pause();
            currentlyPlaying.currentTime = 0;
          }
          audio.currentTime = 0;
          audio.play().catch(error => {
            console.error("Playback failed:", error);
          });
          currentlyPlaying = audio;
        });

        // Mobile double-tap
        img.addEventListener("touchend", () => {
          const now = Date.now();
          if (now - lastTap < 300) {
            if (currentlyPlaying && currentlyPlaying !== audio) {
              currentlyPlaying.pause();
              currentlyPlaying.currentTime = 0;
            }
            audio.currentTime = 0;
            audio.play().catch(error => {
              console.error("Playback failed:", error);
            });
            currentlyPlaying = audio;
          }
          lastTap = now;
        });
      });
    });
  </script>

</body>
</html>
