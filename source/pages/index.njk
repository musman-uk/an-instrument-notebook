<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <title>Seasonal Notes</title>

  <style>
    body {
      font-family: "Bradley Hand", cursive;
      background: #faf9f6;
      color: #222;
      margin: 0;
      padding: 2rem;
      line-height: 1.6;

      /* Soft paper texture */
      background-image:
        radial-gradient(rgba(0,0,0,0.03) 1px, transparent 1px),
        linear-gradient(0deg, rgba(255,255,255,0.6), rgba(255,255,255,0.6));
      background-size: 4px 4px, 100% 100%;
    }

    /* Title card */
    .title-card {
      background: #fff8d6;
      color: #1a4b8c;
      padding: 1rem 2rem;
      border: 1px solid #e0dfd8;
      box-shadow: 2px 3px 6px rgba(0,0,0,0.1);
      font-size: 2rem;
      width: fit-content;
      margin: 0 auto 2rem auto;
      transform: rotate(-1deg);
      letter-spacing: 1px;

      /* Watercolour wash behind title */
      position: relative;
    }

    .title-card::before {
      content: "";
      position: absolute;
      top: -20px;
      left: -30px;
      width: 180%;
      height: 180%;
      background: radial-gradient(circle, rgba(255,240,180,0.4), transparent 70%);
      z-index: -1;
      transform: rotate(3deg);
    }

    /* About link */
    .about-link {
      position: fixed;
      top: 1rem;
      right: 1rem;
      background: #fff8d6;
      padding: 0.6rem 1rem;
      border: 1px solid #e0dfd8;
      box-shadow: 2px 3px 6px rgba(0,0,0,0.1);
      transform: rotate(2deg);
      font-family: "Bradley Hand", cursive;
      text-decoration: none;
      color: #1a4b8c;
      z-index: 10;
    }

    /* Organic 2×2 seasonal layout */
    .seasons-grid {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 2rem;
      position: relative;
    }

    /* Seasonal block base */
    .season-block {
      padding: 1.5rem;
      border-radius: 6px;
      box-shadow: 2px 3px 6px rgba(0,0,0,0.08);
      transform: rotate(var(--tilt));
      position: relative;
      overflow: hidden;
    }

    /* Watercolour textures + palettes */
    .spring {
      background: #e3f7e3;
      --tilt: -1deg;
      color: #2f6b3f;
    }
    .spring::before {
      content: "";
      position: absolute;
      inset: 0;
      background: radial-gradient(circle at 20% 30%, rgba(180,255,200,0.5), transparent 70%),
                  radial-gradient(circle at 80% 70%, rgba(255,200,230,0.4), transparent 70%);
      pointer-events: none;
    }

    .summer {
      background: #ffefb8;
      --tilt: 0.8deg;
      color: #1a6fa8;
    }
    .summer::before {
      content: "";
      position: absolute;
      inset: 0;
      background: radial-gradient(circle at 30% 20%, rgba(255,220,120,0.5), transparent 70%),
                  radial-gradient(circle at 70% 80%, rgba(120,200,255,0.4), transparent 70%);
      pointer-events: none;
    }

    .autumn {
      background: #f7d4b8;
      --tilt: -0.6deg;
      color: #7a2e1a;
    }
    .autumn::before {
      content: "";
      position: absolute;
      inset: 0;
      background: radial-gradient(circle at 20% 80%, rgba(200,120,60,0.4), transparent 70%),
                  radial-gradient(circle at 80% 20%, rgba(255,150,90,0.4), transparent 70%);
      pointer-events: none;
    }

    .winter {
      background: #dcecff;
      --tilt: 1deg;
      color: #1a3f7a;
    }
    .winter::before {
      content: "";
      position: absolute;
      inset: 0;
      background: radial-gradient(circle at 50% 10%, rgba(180,220,255,0.5), transparent 70%),
                  radial-gradient(circle at 30% 90%, rgba(200,240,255,0.4), transparent 70%);
      pointer-events: none;
    }

    .season-title {
      font-size: 1.4rem;
      margin-bottom: 1rem;
      letter-spacing: 1px;
    }

    /* Notes */
    .note {
      background: #fff8d6;
      padding: 0.5rem;
      width: 150px;
      border: 1px solid #e0dfd8;
      box-shadow: 2px 3px 6px rgba(0,0,0,0.1);
      transform: rotate(-2deg);
      font-size: 0.9rem;
      margin: 0.4rem;
      opacity: 0;
      color: #1a4b8c;
      transition: opacity 0.6s ease, transform 0.6s ease;
    }

    .note.visible {
      opacity: 1;
      transform: rotate(var(--tilt-note, -1deg));
    }

    .notes-wrap {
      display: flex;
      flex-wrap: wrap;
      gap: 0.4rem;
    }

    /* Mobile layout */
    @media (max-width: 700px) {
      .seasons-grid {
        grid-template-columns: 1fr;
      }
      .season-block {
        transform: rotate(0deg);
      }
    }
  </style>
</head>

<body>

  <a class="about-link" href="about/">About</a>

  <div class="title-card">Seasonal Notes</div>

  <div class="seasons-grid">

    {% for season in ["spring", "summer", "autumn", "winter"] %}
      <div class="season-block {{ season }}">
        <div class="season-title">{{ season | capitalize }}</div>

        <div class="notes-wrap">
          {% for note in collections.notes %}
            {% if note.data.season == season %}
              <div class="note">
                {{ note.templateContent | safe }}
              </div>
            {% endif %}
          {% endfor %}
        </div>
      </div>
    {% endfor %}

  </div>

  <script>
    document.addEventListener("DOMContentLoaded", () => {
      const notes = document.querySelectorAll(".note");

      notes.forEach((note, i) => {
        const delay = 200 + i * 120;
        setTimeout(() => {
          note.classList.add("visible");
        }, delay);
      });
    });
  </script>

</body>
</html>
