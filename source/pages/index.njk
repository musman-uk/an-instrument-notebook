<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <title>Seasonal Notes</title>

  <style>
    body {
      font-family: "Bradley Hand", "Comic Sans MS", cursive;
      background: #faf9f6;
      color: #222;
      margin: 0;
      padding: 2rem;
      line-height: 1.6;
    }

    h1 {
      font-size: 2rem;
      margin-bottom: 2rem;
      letter-spacing: 1px;
    }

    /* Sticky-note style About link */
    .about-link {
      position: fixed;
      top: 1rem;
      right: 1rem;
      background: #fffef7;
      padding: 0.6rem 1rem;
      border: 1px solid #e0dfd8;
      box-shadow: 2px 3px 6px rgba(0,0,0,0.1);
      transform: rotate(2deg);
      font-family: "Bradley Hand", cursive;
      text-decoration: none;
      color: #222;
      z-index: 10;
    }

    /* Container for desktop layout */
    .notes-container {
      display: flex;
      flex-wrap: wrap;
      gap: 1.5rem;
      align-items: flex-start;
      margin-top: 2rem;
    }

    .season {
      width: 100%;
      margin-top: 3rem;
      font-size: 1.4rem;
      font-weight: bold;
      text-transform: uppercase;
      letter-spacing: 2px;
      opacity: 0.7;
    }

    .note {
      background: #fffef7;
      padding: 1rem;
      width: 260px;
      border: 1px solid #e0dfd8;
      box-shadow: 2px 3px 6px rgba(0,0,0,0.1);
      transform: rotate(-1deg);
      font-family: "Bradley Hand", cursive;
      font-size: 1.1rem;

      opacity: 0;
      transition: opacity 0.6s ease, transform 0.6s ease;
    }

    .note.visible {
      opacity: 1;
      transform: rotate(var(--tilt, -1deg));
    }

    /* Seasonal palettes */
    .note-spring {
      background: #e8fbe8;
      border-color: #b8e6b8;
    }

    .note-summer {
      background: #fff4c7;
      border-color: #ffd98a;
    }

    .note-autumn {
      background: #ffe8d9;
      border-color: #f2b48c;
    }

    .note-winter {
      background: #e7f1ff;
      border-color: #c7d9f2;
    }
  </style>
</head>

<body>

  <a class="about-link" href="about/">About</a>

  <h1>Seasonal Notes</h1>

  <div class="notes-container">

    {% for season in ["spring", "summer", "autumn", "winter"] %}
      <div class="season">{{ season | capitalize }}</div>

      {% for note in collections.notes %}
        {% if note.data.season == season %}
          <div class="note note-{{ season }}">
            {{ note.templateContent | safe }}
          </div>
        {% endif %}
      {% endfor %}
    {% endfor %}

  </div>

  <script>
    document.addEventListener("DOMContentLoaded", () => {
      const notes = document.querySelectorAll(".note");

      notes.forEach((note, i) => {
        const delay = 200 + i * 150;
        setTimeout(() => {
          note.classList.add("visible");
        }, delay);
      });
    });
  </script>

</body>
</html>
